# ============================================================
# App identity (used in title bar + PWA manifest)
# ============================================================
VITE_APP_TITLE=مساعد الحجوزات
VITE_APP_SHORT_NAME=حجوزات

# ============================================================
# OpenAI Realtime API
# Get your key at https://platform.openai.com/api-keys
#
# WARNING: this key ends up in the browser bundle. For prototype
# testing only. In production, mint ephemeral tokens via a small
# backend (Firebase Function works well).
# ============================================================
VITE_OPENAI_API_KEY=sk-proj-...

# - gpt-realtime-mini: cheap + fast, fine for most tool-driven tasks
# - gpt-realtime:      higher quality voice, ~4x more expensive
VITE_REALTIME_MODEL=gpt-realtime-mini

# cedar, marin, sage, verse, alloy, nova, shimmer, echo, fable, onyx, ash
# Marin & cedar are the newest. Sage & verse handle Arabic well.
VITE_REALTIME_VOICE=marin

# ============================================================
# Firebase — powers both the auth gate (email/password) AND the
# Firestore data layer (services, stylists, settings, appointments,
# customers) as of Phase 2.
#
# Leave blank to run in mock-data mode: auth is bypassed and the app
# reads bundled seed data from src/domain/data/seed-data.ts, with
# bookings kept in memory (reset on reload). Good for local UI work.
#
# When configured, seed Firestore once by opening the dev server with
# ?seed=1 (e.g. https://<lan-ip>:5173/?seed=1), click "Seed Firestore",
# then remove ?seed=1.
# ============================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
